#!/bin/bash
# Multi-source rule aggregation: downloads from multiple upstreams and merges by type.
# Sources are defined in sources.d/*.conf (KEY=VALUE format, one source per file).
#
# Output files per TYPE:
#   chnroute   → Domains.chn.txt (merged domain list)
#   chnlist    → IPchnroute        (merged CIDR list)
#   apple      → Domains.apple.txt
#   games      → Domains.games.txt
#   bogus      → 99-bogus-nxdomain.china.conf
#   geosite    → geosite.dat       (primary only; binary blob)
#   geoip      → geoip.dat         (primary only; binary blob)

set -euo pipefail

SOURCES_DIR="/opt/de_GWD/sources.d"
STAGING="/tmp/de_GWD_merge"
REPO_DIR="/opt/de_GWD/.repo"
LAST_GOOD_DIR="/opt/de_GWD/.repo/prev"

rm -rf "$STAGING"
mkdir -p "$STAGING" "$LAST_GOOD_DIR"

# ── Download helper ───────────────────────────────────────────────────

ETAG_DIR="$REPO_DIR/.etags"

download_with_fallback(){
	local url="$1" mirror="$2" dest="$3" name="$4"
	local etag_file="$ETAG_DIR/$name.etag"
	local http_code

	# Try conditional download with ETag
	if [[ -f "$etag_file" ]]; then
		http_code=$(curl -fsSLo "$dest" -m 30 -H "If-None-Match: $(cat "$etag_file")" -w "%{http_code}" "$url" 2>/dev/null)
		if [[ $http_code = "304" ]]; then
			return 0
		elif [[ $http_code = "200" ]]; then
			curl -fsSLI -m 10 "$url" 2>/dev/null | grep -i '^etag:' | awk '{print $2}' | tr -d '\r"' > "$etag_file"
			return 0
		fi
	fi

	if curl -fsSLo "$dest" -m 30 "$url"; then
		curl -fsSLI -m 10 "$url" 2>/dev/null | grep -i '^etag:' | awk '{print $2}' | tr -d '\r"' > "$etag_file"
		return 0
	fi

	echo "  Mirror fallback..." >&2
	if curl -fsSLo "$dest" -m 30 "$mirror"; then
		return 0
	fi
	return 1
}

# ── Format converters ────────────────────────────────────────────────

# Convert dnsmasq-server format to plain domain list
# Input:  server=/domain.com/114.114.114.114
# Output: domain.com
convert_dnsmasq_server(){
	sed -n 's/^server=\/\([^/]*\)\/.*$/\1/p' "$1" | grep -v '^#'
}

# Convert CIDR list: strip comments/blank lines, normalize
normalize_cidr(){
	grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}/[0-9]{1,2}' "$1" || true
}

# Normalize plain domain list: lowercase, strip empty/comments
normalize_domains(){
	grep -v '^#' "$1" | grep -v '^$' | grep -v '^[[:space:]]*$' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' || true
}

# ── Health check ─────────────────────────────────────────────────────

health_check_merged(){
	local file="$1" type="$2"
	case "$type" in
		chnroute)
			local cidr_count
			cidr_count=$(grep -cE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/[0-9]+$' "$file" || true)
			[[ $cidr_count -ge 5000 ]] || { echo "FAIL: only $cidr_count CIDRs"; return 1; }
			;;
		chnlist)
			local line_count
			line_count=$(wc -l < "$file" || true)
			[[ $line_count -ge 1000 ]] || { echo "FAIL: only $line_count domains"; return 1; }
			;;
	esac
	return 0
}

# ── Parse sources.d/ ──────────────────────────────────────────────────

declare -A SRC_URL SRC_MIRROR SRC_SHA SRC_FORMAT SOURCE_TYPES
SOURCE_NAMES=()

for conf in "$SOURCES_DIR"/*.conf; do
	[[ -f "$conf" ]] || continue
	name=$(basename "$conf" .conf)
	SOURCE_NAMES+=("$name")

	# Parse KEY=VALUE
	while IFS='=' read -r key value; do
		[[ -z "$key" || "$key" == \#* ]] && continue
		case "$key" in
			TYPE)    SOURCE_TYPES[$name]="$value" ;;
			PRIMARY) SRC_URL[$name]="$value" ;;
			MIRROR)  SRC_MIRROR[$name]="$value" ;;
			SHA)     SRC_SHA[$name]="$value" ;;
			FORMAT)  SRC_FORMAT[$name]="$value" ;;
		esac
	done < "$conf"
done

# ── Download & convert all sources ────────────────────────────────────

declare -A raw_files
for name in "${SOURCE_NAMES[@]}"; do
	type="${SOURCE_TYPES[$name]}"
	raw="$STAGING/raw_${name}.txt"
	raw_files[$name]="$raw"

	if download_with_fallback "${SRC_URL[$name]}" "${SRC_MIRROR[$name]}" "$raw" "$name"; then
		# Convert format if needed
		case "${SRC_FORMAT[$name]:-plain}" in
			dnsmasq-server)
				convert_dnsmasq_server "$raw" > "$STAGING/${name}_converted.txt"
				mv "$STAGING/${name}_converted.txt" "$raw"
				;;
			plain|cidr|*)
				;;
		esac
		echo "  [OK] $name ($type) downloaded"
	else
		echo "  [FAIL] $name ($type) download failed"
		rm -f "$raw"
	fi
done

# ── Merge by type ─────────────────────────────────────────────────────

declare -A merged_files
for type in chnroute chnlist; do
	merged="$STAGING/merged_${type}.txt"
	merged_files[$type]="$merged"
	touch "$merged"

	for name in "${SOURCE_NAMES[@]}"; do
		[[ "${SOURCE_TYPES[$name]}" == "$type" ]] || continue
		raw="${raw_files[$name]}"
		[[ -f "$raw" ]] || continue

		case "$type" in
			chnroute) normalize_cidr "$raw" >> "$merged" ;;
			chnlist)  normalize_domains "$raw" >> "$merged" ;;
		esac
	done

	# Deduplicate and sort
	case "$type" in
		chnroute) sort -t. -k1,1n -k2,2n -k3,3n -k4,4n -u "$merged" | sponge "$merged" ;;
		chnlist)  sort -u "$merged" | sponge "$merged" ;;
	esac

	# Health check
	count=$(wc -l < "$merged")
	if health_check_merged "$merged" "$type"; then
		echo "  [OK] Merged $type: $count entries"
	else
		echo "  [FAIL] Merged $type: $count entries (below threshold)"
		# Restore from last-good if available
		if [[ -f "$LAST_GOOD_DIR/$(basename "${merged_files[$type]}")" ]]; then
			cp "$LAST_GOOD_DIR/$(basename "${merged_files[$type]}")" "$merged"
			echo "  [RESTORE] $type from last-good backup"
		fi
	fi
done

# ── Atomically install merged files ───────────────────────────────────

install_merged(){
	local type="$1" repo_file="$2"
	local merged="${merged_files[$type]}"
	[[ -f "$merged" ]] || return 1

	# Backup current
	[[ -f "$repo_file" ]] && cp "$repo_file" "$LAST_GOOD_DIR/$(basename "$repo_file")"

	# Install
	cp "$merged" "$repo_file"
	echo "  [INSTALL] $repo_file ($(wc -l < "$merged") entries)"
}

install_merged chnroute "$REPO_DIR/IPchnroute"
install_merged chnlist  "$REPO_DIR/Domains.chn.txt"

# ── Cleanup ───────────────────────────────────────────────────────────
rm -rf "$STAGING"
